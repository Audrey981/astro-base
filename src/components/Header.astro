---
// Script : props optionnelles
import Navigation from './Navigation.astro';
import logo from '../images/cjal.png'
---
<header>

<div class="header-logo"><img src={logo.src} alt="logo de la carte de visite CJAL" width="auto" height="50"></div>

<Navigation>

</Navigation>
  
</header>

<style>
header {
  background-color:  #2f2559; 
  color: #ffffff;
  display: flex;
  align-items: center;
  padding-right: 20rem;
}
.header-logo {
  background-color:#2f2559 ;
  display: flex;
  padding: 1rem 20rem;
}
@media (max-width: 900px) {
  header {
    padding-right: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .header-logo {
    padding: 0.75rem 1rem;
  }
}

@media (max-width: 480px) {
  header {
    padding-right: 0.5rem;
  }
  .header-logo {
    padding: 0.5rem;
  }
}

</style>